.pkg-badge-cuadernos {
  background: #dbeafe;
  color: #1d4ed8;
  border: 1px solid #bfdbfe;
}
.pkg-badge-folios {
  background: #dcfce7;
  color: #15803d;
  border: 1px solid #bbf7d0;

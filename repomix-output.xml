        param: anexo.jwt.param,
        filename: `${pkg.rol}_anexo_${i + 1}_${cleanRef}.pdf`,
        document_type: 'anexo',
        folio: null,
        cuaderno: null,
        fecha: anexo.fecha || null,
        source_url: anexo.jwt.action,
        referencia: anexo.referencia || undefined,
      })
